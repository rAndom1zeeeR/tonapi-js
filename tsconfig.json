{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "noEmit": true,
    "baseUrl": ".",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "paths": {
      "@ton-api/client": ["./packages/client/src/client.ts"],
      "@ton-api/ton-adapter": ["./packages/ton-adapter/src/index.ts"]
    }
  },
  "include": [
    "tests/**/*.ts",
    "examples/**/*.ts"
  ],
  "exclude": [
    "node_modules/**",
    "packages/**/dist/**",
    "packages/**/node_modules/**",
    "tests/client/__mock__/fetchMock.ts"
  ]
}
