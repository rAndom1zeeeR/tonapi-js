  <% for (const route of routes.outOfModule) { %>

<%~ includeFile('./procedure-call.ejs', { ...it, route, isFlat: true }) %>

  <% } %>
<% } %>

<% if (routes.combined) { %>
  <% for (const { routes: combinedRoutes = [], moduleName } of routes.combined) { %>
    <% for (const route of combinedRoutes) { %>

<%~ includeFile('./procedure-call.ejs', { ...it, route, isFlat: true }) %>

    <% } %>
  <% } %>
<% } %>
